NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_NAME=NeredeServis Web

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Optional for auth/rtdb bootstrap; required once Firebase Web App registration is created/confirmed
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_MAPBOX_TOKEN=

NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=true
NEXT_PUBLIC_ENABLE_EMAIL_LOGIN=true

# Dev-only fast login helper (optional; local only)
NEXT_PUBLIC_DEV_FAST_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_FAST_LOGIN_PASSWORD=
