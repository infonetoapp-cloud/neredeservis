NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_NAME=NeredeServis Web

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west3

# Optional for auth/rtdb bootstrap; required once Firebase Web App registration is created/confirmed
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_MAPBOX_TOKEN=

NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=true
NEXT_PUBLIC_ENABLE_MICROSOFT_LOGIN=true
NEXT_PUBLIC_ENABLE_EMAIL_LOGIN=true
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=true
NEXT_PUBLIC_REQUIRE_PROFILE_ONBOARDING=true
NEXT_PUBLIC_FORCE_UPDATE_LOCK=false

# Comma-separated dev company ids for /select-company fallback list
NEXT_PUBLIC_DEV_COMPANY_IDS=cmp_demo_001,cmp_demo_002

# Optional: used by live feed probe card
NEXT_PUBLIC_DEFAULT_LIVE_ROUTE_ID=

# Dev-only fast login helper (optional; local only)
NEXT_PUBLIC_DEV_FAST_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_FAST_LOGIN_PASSWORD=
