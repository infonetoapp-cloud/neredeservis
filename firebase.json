{
    "functions":  {
                      "source":  "functions",
                      "predeploy":  [
                                        "npm --prefix \"$RESOURCE_DIR\" run build"
                                    ]
                  },
    "firestore":  {
                      "rules":  "firestore.rules",
                      "indexes":  "firestore.indexes.json"
                  },
    "database":  {
                     "rules":  "database.rules.json"
                 },
    "storage":  {
                    "rules":  "storage.rules"
                },
    "hosting":  [
                    {
                        "target":  "app",
                        "public":  "prototype",
                        "ignore":  [
                                       "firebase.json",
                                       "**/.*",
                                       "**/node_modules/**"
                                   ],
                        "rewrites":  [
                                         {
                                             "source":  "/r/**",
                                             "destination":  "/route-preview.html"
                                         }
                                     ],
                        "headers":  [
                                        {
                                            "source":  "/route-preview.html",
                                            "headers":  [
                                                            {
                                                                "key":  "Cache-Control",
                                                                "value":  "no-store"
                                                            }
                                                        ]
                                        },
                                        {
                                            "source":  "/.well-known/assetlinks.json",
                                            "headers":  [
                                                            {
                                                                "key":  "Content-Type",
                                                                "value":  "application/json; charset=utf-8"
                                                            },
                                                            {
                                                                "key":  "Cache-Control",
                                                                "value":  "public, max-age=300"
                                                            }
                                                        ]
                                        },
                                        {
                                            "source":  "/.well-known/apple-app-site-association",
                                            "headers":  [
                                                            {
                                                                "key":  "Content-Type",
                                                                "value":  "application/json; charset=utf-8"
                                                            },
                                                            {
                                                                "key":  "Cache-Control",
                                                                "value":  "public, max-age=300"
                                                            }
                                                        ]
                                        }
                                    ]
                    }
                ],
    "emulators":  {
                      "auth":  {
                                   "port":  9099
                               },
                      "functions":  {
                                        "port":  5001
                                    },
                      "firestore":  {
                                        "port":  8080
                                    },
                      "database":  {
                                       "port":  9000
                                   },
                      "hosting":  {
                                      "port":  5000
                                  },
                      "ui":  {
                                 "enabled":  true,
                                 "port":  4000
                             },
                      "singleProjectMode":  true
                  }
}
