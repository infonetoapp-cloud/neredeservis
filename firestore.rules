rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function routeDoc(routeId) {
      return get(/databases/$(database)/documents/routes/$(routeId)).data;
    }

    function isRouteMember(routeId) {
      return signedIn() &&
        routeDoc(routeId).memberIds is list &&
        request.auth.uid in routeDoc(routeId).memberIds;
    }

    function isRouteDriver(routeId) {
      return signedIn() && routeDoc(routeId).driverId == request.auth.uid;
    }

    function isAuthorizedDriver(routeId) {
      return signedIn() &&
        routeDoc(routeId).authorizedDriverIds is list &&
        request.auth.uid in routeDoc(routeId).authorizedDriverIds;
    }

    function isRouteReader(routeId) {
      return isRouteMember(routeId) || isRouteDriver(routeId) || isAuthorizedDriver(routeId);
    }

    function currentRouteAllowsDriverRead() {
      return signedIn() && (
        resource.data.driverId == request.auth.uid ||
        (
          resource.data.authorizedDriverIds is list &&
          request.auth.uid in resource.data.authorizedDriverIds
        ) ||
        (
          resource.data.memberIds is list &&
          request.auth.uid in resource.data.memberIds
        )
      );
    }

    function conversationDoc(conversationId) {
      return get(/databases/$(database)/documents/trip_conversations/$(conversationId)).data;
    }

    function isConversationParticipant(conversationId) {
      return signedIn() &&
        conversationDoc(conversationId) != null &&
        conversationDoc(conversationId).participantUids is list &&
        request.auth.uid in conversationDoc(conversationId).participantUids;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow write, delete: if false;
    }

    // 073A: No direct Firestore reads. Search only via callable.
    match /driver_directory/{driverId} {
      allow read, write, delete: if false;
    }

    match /drivers/{driverId} {
      allow read: if isSelf(driverId);
      allow write, delete: if false;
    }

    match /routes/{routeId} {
      // Driver "Seferlerim" queries read routes by driverId / authorizedDriverIds.
      // These checks must be query-friendly (resource.data based), not routeDoc(get()) only.
      allow get: if currentRouteAllowsDriverRead();
      allow list: if signedIn() && (
        resource.data.driverId == request.auth.uid ||
        (
          'authorizedDriverIds' in resource.data &&
          request.auth.uid in resource.data.authorizedDriverIds
        ) ||
        (
          'memberIds' in resource.data &&
          request.auth.uid in resource.data.memberIds
        )
      );
      allow write: if false;
    }

    match /routes/{routeId}/stops/{stopId} {
      allow read: if isRouteReader(routeId);
      allow write: if false;
    }

    match /routes/{routeId}/passengers/{passengerId} {
      allow read: if isSelf(passengerId) || isAuthorizedDriver(routeId) || isRouteDriver(routeId);
      allow write: if false;
    }

    // 073: skip request visibility is limited to passenger + route drivers.
    match /routes/{routeId}/skip_requests/{skipRequestId} {
      allow read: if (
        signedIn() && request.auth.uid == resource.data.passengerId
      ) || isAuthorizedDriver(routeId) || isRouteDriver(routeId);
      allow write: if false;
    }

    match /trips/{tripId} {
      allow read: if signedIn() && (
        resource.data.driverId == request.auth.uid ||
        isRouteReader(resource.data.routeId)
      );
      allow write: if false;
    }

    match /announcements/{announcementId} {
      allow read: if signedIn() && isRouteReader(resource.data.routeId);
      allow write: if false;
    }

    match /trip_conversations/{conversationId} {
      allow read: if isConversationParticipant(conversationId);
      allow write: if false;
    }

    match /trip_conversations/{conversationId}/messages/{messageId} {
      allow read: if isConversationParticipant(conversationId);
      allow write: if false;
    }

    match /guest_sessions/{sessionId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.guestUid ||
        isRouteDriver(resource.data.routeId) ||
        isAuthorizedDriver(resource.data.routeId)
      );
      allow write: if false;
    }

    match /consents/{uid} {
      allow read: if isSelf(uid);
      allow write, delete: if false;
    }

    match /trip_requests/{id} {
      allow read, write, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
